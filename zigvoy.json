{
  "listen_port": 8080,
  "admin_port": 9901,
  "routes": [
    {
      "prefix": "/api/",
      "upstream": "backend"
    },
    {
      "prefix": "/",
      "upstream": "frontend"
    }
  ],
  "upstreams": [
    {
      "name": "backend",
      "lb_policy": "round_robin",
      "endpoints": [
        { "host": "127.0.0.1", "port": 3000 },
        { "host": "127.0.0.1", "port": 3001 }
      ]
    },
    {
      "name": "frontend",
      "lb_policy": "round_robin",
      "endpoints": [
        { "host": "127.0.0.1", "port": 5173 }
      ]
    }
  ],
  "health_check": {
    "interval_ms": 5000,
    "timeout_ms": 2000,
    "unhealthy_threshold": 3,
    "healthy_threshold": 1,
    "path": "/healthz"
  },
  "rate_limit": {
    "enabled": true,
    "requests_per_second": 100,
    "burst_size": 50
  },
  "circuit_breaker": {
    "enabled": true,
    "failure_threshold": 5,
    "reset_timeout_ms": 30000,
    "half_open_max_requests": 3
  },
  "retry": {
    "max_retries": 3
  }
}
